{
  "name": "whale-play",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @neo-tavern/desktop dev",
    "build": "pnpm --filter @neo-tavern/desktop build",
    "build:desktop": "pnpm --filter @neo-tavern/desktop tauri build",
    "typecheck": "pnpm --filter @neo-tavern/desktop typecheck",
    "tauri": "pnpm --filter @neo-tavern/desktop tauri",
    "test": "pnpm --filter @neo-tavern/desktop test && pnpm --filter @neo-tavern/core test",
    "test:watch": "pnpm --filter @neo-tavern/desktop test:watch && pnpm --filter @neo-tavern/core test:watch",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.60.0"
  }
}
